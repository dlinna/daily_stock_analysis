# ===================================
# A股自选股智能分析系统 - 完整.env配置（AIHUBMIX + QQ邮箱推送）
# ===================================

# ---------------- 核心自选股配置 ----------------
# 替换为你关注的股票代码（逗号分隔）
STOCK_LIST=603936,600072

# ---------------- 数据源配置（可选）----------------
# Tushare Token（无需则留空）
TUSHARE_TOKEN=

# ---------------- 定时任务配置 ----------------
# 启用每日定时分析（收盘后执行）
SCHEDULE_ENABLED=true
# 每日执行时间（24小时制，建议18:00收盘后）
SCHEDULE_TIME=17:00
# 启动程序时立即执行一次分析（验证配置是否生效）
RUN_IMMEDIATELY=true
# 仅交易日执行（非交易日跳过）
TRADING_DAY_CHECK_ENABLED=true

# ---------------- AI模型配置（核心）----------------
# AIHubmix Key（必填，替换为你的key）
AIHUBMIX_KEY=sk-4Qltto54aJTMoVvABe9bF27687A843Db99829f2123093aF2
# 采样温度（默认0.7，无需修改）
LLM_TEMPERATURE=0.7
# LiteLLM配置文件路径（关键：关联多模型配置）
LITELLM_CONFIG=./litellm_config.yaml
LITELLM_MODEL=openai/gemini-3-flash-preview-free
# ---------------- 搜索引擎配置（可选）----------------
# 无需则全部留空
BOCHA_API_KEYS=
TAVILY_API_KEYS=
SERPAPI_API_KEYS=fffbe101e0114f4d385ae6cdda289c7579cab6d66b9794a4245e4af09da84bb2
BRAVE_API_KEYS=
SEARXNG_BASE_URLS=

# ---------------- 新闻/分析筛选配置 ----------------
NEWS_MAX_AGE_DAYS=3
BIAS_THRESHOLD=5.0

# ---------------- Agent策略配置 ----------------
AGENT_SKILLS=bull_trend,ma_golden_cross,volume_breakout,shrink_pullback
AGENT_ARCH=single
AGENT_ORCHESTRATOR_MODE=standard

# ---------------- 通知渠道（QQ邮箱核心配置）----------------
# QQ邮箱发送方（必填：你的QQ邮箱地址，如 123456@qq.com）
EMAIL_SENDER=340776075@qq.com
# QQ邮箱授权码
EMAIL_PASSWORD=zljckhwngwiccafa
# 收件人（可选：留空则发送到上述发送方邮箱；多个收件人用逗号分隔）
EMAIL_RECEIVERS=340776075@qq.com
# 个股分析+大盘复盘合并推送（减少邮件数量）
MERGE_EMAIL_NOTIFICATION=true

# ---------------- 单股推送配置 ----------------
SINGLE_STOCK_NOTIFY=false
REPORT_TYPE=full
REPORT_SUMMARY_ONLY=false

# ---------------- 其他通知渠道（留空即可）----------------
WECHAT_WEBHOOK_URL=
FEISHU_WEBHOOK_URL=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
CUSTOM_WEBHOOK_URLS=
PUSHOVER_USER_KEY=
PUSHPLUS_TOKEN=
SERVERCHAN3_SENDKEY=
DISCORD_WEBHOOK_URL=

# ---------------- 钉钉/飞书应用配置（留空）----------------
DINGTALK_APP_KEY=
DINGTALK_APP_SECRET=
DINGTALK_STREAM_ENABLED=false
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_STREAM_ENABLED=false

# ---------------- 数据库配置 ----------------
DATABASE_PATH=./data/stock_analysis.db

# ---------------- 回测配置 ----------------
BACKTEST_ENABLED=true
BACKTEST_EVAL_WINDOW_DAYS=10
BACKTEST_MIN_AGE_DAYS=14
BACKTEST_ENGINE_VERSION=v1
BACKTEST_NEUTRAL_BAND_PCT=2.0

# ---------------- 大盘复盘配置 ----------------
MARKET_REVIEW_ENABLED=true
MARKET_REVIEW_REGION=cn

# ---------------- 代理配置（无需则关闭）----------------
USE_PROXY=false
PROXY_HOST=127.0.0.1
PROXY_PORT=10809

# ---------------- 系统配置 ----------------
LOG_DIR=./logs
LOG_LEVEL=INFO
MAX_WORKERS=3
DEBUG=false

# ---------------- WebUI配置（可选启用）----------------
WEBUI_ENABLED=false
WEBUI_HOST=127.0.0.1
WEBUI_PORT=8000
WEBUI_AUTO_BUILD=true
ADMIN_AUTH_ENABLED=false

# ---------------- 实时行情配置 ----------------
REALTIME_SOURCE_PRIORITY=tencent,akshare_sina,efinance,akshare_em
ENABLE_REALTIME_QUOTE=true
ENABLE_REALTIME_TECHNICAL_INDICATORS=true
ENABLE_CHIP_DISTRIBUTION=false
ENABLE_FUNDAMENTAL_PIPELINE=true

# ---------------- 东财接口补丁（默认关闭）----------------
ENABLE_EASTMONEY_PATCH=false
