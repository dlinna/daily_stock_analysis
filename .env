# ===================================
# A股自选股智能分析系统 - YAML高级配置模式
# ===================================

# ---------------- 核心自选股配置 ----------------
STOCK_LIST=603936,603601,002195,000010,600370,000014,002459,601908,600012,002155

# ---------------- 数据源配置 ----------------
TUSHARE_TOKEN=

# ---------------- 定时任务配置 ----------------
SCHEDULE_ENABLED=true
SCHEDULE_TIME=12:00
RUN_IMMEDIATELY=true
TRADING_DAY_CHECK_ENABLED=true

# ---------------- 【YAML高级配置 - 唯一入口】----------------
LITELLM_CONFIG=./litellm_config.yaml
# 指定主模型
LITELLM_MODEL=Qwen3-VL-32B-Thinking
# 指定备用模型（系统内置的故障转移机制）
LITELLM_FALLBACK_MODELS=deepseek-v3-2-exp,gpt4o-mini-chatanywhere,gemini-3-flash-preview-free

# ---------------- API密钥（供YAML引用，非直接配置）----------------
